<div class="container">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow animate__animated animate__fadeInUp">
                <div class="card-body p-5">
                    <div class="text-center mb-4 animate__animated animate__fadeInDown">
                        <h2 class="fw-bold">Welcome Back</h2>
                        <p class="text-muted">Sign in to manage your AI chatbot</p>
                    </div>

                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-danger animate__animated animate__shakeX" role="alert">
                            <%= error %>
                        </div>
                        <% } %>

                            <form id="signinForm" method="POST" action="/auth/signin">
                                <div class="mb-3 animate__animated animate__fadeInLeft">
                                    <label for="email" class="form-label">Email Address</label>
                                    <input type="email" class="form-control" id="email" name="email" required
                                        placeholder="you@example.com">
                                </div>
                                <div class="mb-3 animate__animated animate__fadeInRight">
                                    <label for="password" class="form-label">Password</label>
                                    <div class="position-relative">
                                        <input type="password" class="form-control" id="password" name="password"
                                            required placeholder="Enter your password">
                                        <button type="button"
                                            class="btn border-0 outline-none position-absolute top-50 end-0 translate-middle-y"
                                            id="togglePassword">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                </div>
                                <div class="d-grid animate__animated animate__fadeInUp">
                                    <button type="submit" class="btn btn-primary btn-lg">Sign In</button>
                                </div>
                            </form>

                            <div class="text-center mt-4 animate__animated animate__fadeIn">
                                <p class="mb-0">Don't have an account? <a href="/auth/signup"
                                        class="text-decoration-none">Sign Up</a></p>
                            </div>
                </div>
            </div>
        </div>
    </div>
</div>