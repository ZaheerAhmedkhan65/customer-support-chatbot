<div class="container" data-page="signup">
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow animate__animated animate__fadeInUp">
                <div class="card-body p-5">
                    <div class="text-center mb-4 animate__animated animate__fadeInDown">
                        <h2 class="fw-bold">Create Your Account</h2>
                        <p class="text-muted">Start providing 24/7 AI customer support</p>
                    </div>

                    <div class="d-grid">
                        <a href="/auth/google"
                            class="btn btn-outline-dark bg-white text-dark fw-semibold py-2 px-4 rounded-3 shadow-sm d-flex align-items-center justify-content-center">
                            <img src="/google.svg" alt="google" class="me-2" style="width:20px; height:20px;">
                            Continue with Google
                        </a>
                    </div>
                    
                    <div class="d-flex align-items-center justify-content-center mx-2 my-4">
                        <div class="border-bottom border-1 border-secondary w-100"></div>
                        <p class="mb-0 mx-2 text-muted">OR</p>
                        <div class="border-bottom border-1 border-secondary w-100"></div>
                    </div>
                    
                    <% if (typeof error !== 'undefined' && error) { %>
                        <div class="alert alert-danger animate__animated animate__shakeX" role="alert">
                            <%= error %>
                        </div>
                    <% } %>
                    
                    <form method="POST" action="/auth/signup">
                        <div class="mb-3 animate__animated animate__fadeInLeft">
                            <label for="email" class="form-label">Email</label>
                            <input type="email" class="form-control" id="email" name="email" required 
                                   placeholder="you@example.com">
                        </div>
                        <div class="mb-3 animate__animated animate__fadeInRight">
                            <label for="password" class="form-label">Password</label>
                            <div class="position-relative">
                                <input type="password" class="form-control" id="password" name="password" required
                                    placeholder="Enter your password">
                                <button type="button" class="btn border-0 outline-none position-absolute top-50 end-0 translate-middle-y"
                                    id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="d-grid animate__animated animate__fadeInUp">
                            <button type="submit" class="btn btn-primary btn-lg">Sign Up</button>
                        </div>
                    </form>
                    
                    <div class="text-center mt-4 animate__animated animate__fadeIn">
                        <p class="mb-0 text-muted">Already have an account? <a data-link href="/auth/signin" class="text-decoration-none">Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>