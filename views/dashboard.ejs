<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - AI Customer Support Chatbot</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <nav class="dashboard-nav">
        <div class="nav-container">
            <div class="logo">
                <span class="logo-icon">🤖</span>
                <span class="logo-text">AI Support Bot</span>
            </div>
            <div class="nav-links">
                <span id="userEmail" class="user-email"><%= user ? user.email : '' %></span>
                <a href="/auth/logout" class="btn-secondary">Logout</a>
            </div>
        </div>
    </nav>

    <div class="dashboard-container">
        <div class="sidebar">
            <div class="sidebar-menu">
                <a href="/dashboard" class="menu-item <%= !tab || tab === 'settings' ? 'active' : '' %>">Chatbot Settings</a>
                <a href="/dashboard?tab=knowledge" class="menu-item <%= tab === 'knowledge' ? 'active' : '' %>">Knowledge Base</a>
                <a href="/dashboard?tab=embed" class="menu-item <%= tab === 'embed' ? 'active' : '' %>">Embed Script</a>
                <a href="/dashboard?tab=analytics" class="menu-item <%= tab === 'analytics' ? 'active' : '' %>">Analytics</a>
            </div>
        </div>

        <div class="main-content">
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="success-message"><%= success %></div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="error-message"><%= error %></div>
            <% } %>

            <!-- Settings Tab -->
            <div id="settings" class="tab-content <%= !tab || tab === 'settings' ? 'active' : '' %>">
                <h2>Chatbot Settings</h2>
                <form method="POST" action="/api/chatbot/settings">
                    <input type="hidden" name="_method" value="PUT">
                    <div class="form-group">
                        <label>Business Name</label>
                        <input type="text" name="business_name" value="<%= chatbot && chatbot.business_name ? chatbot.business_name : '' %>" placeholder="Your Business Name">
                    </div>
                    <div class="form-group">
                        <label>Business Email</label>
                        <input type="email" name="business_email" value="<%= chatbot && chatbot.business_email ? chatbot.business_email : '' %>" placeholder="support@yourbusiness.com">
                    </div>
                    <div class="form-group">
                        <label>Theme Color</label>
                        <input type="color" name="theme_color" value="<%= chatbot && chatbot.theme_color ? chatbot.theme_color : '#3B82F6' %>">
                    </div>
                    <div class="form-group">
                        <label>Button Position</label>
                        <select name="button_position">
                            <option value="right" <%= chatbot && chatbot.button_position === 'right' ? 'selected' : '' %>>Right</option>
                            <option value="left" <%= chatbot && chatbot.button_position === 'left' ? 'selected' : '' %>>Left</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Welcome Message</label>
                        <textarea name="welcome_message" rows="3" placeholder="Hello! How can I help you today?"><%= chatbot && chatbot.welcome_message ? chatbot.welcome_message : 'Hello! How can I help you today?' %></textarea>
                    </div>
                    <button type="submit" class="btn-primary">Save Settings</button>
                </form>
            </div>

            <!-- Knowledge Base Tab -->
            <div id="knowledge" class="tab-content <%= tab === 'knowledge' ? 'active' : '' %>">
                <h2>Knowledge Base</h2>
                <div class="knowledge-form">
                    <h3>Add New Content</h3>
                    <form method="POST" action="/api/chatbot/knowledge">
                        <div class="form-group">
                            <label>Content Type</label>
                            <select name="content_type">
                                <option value="faq">FAQ</option>
                                <option value="policy">Policy</option>
                                <option value="delivery">Delivery Info</option>
                                <option value="refund">Refund Policy</option>
                                <option value="product">Product Details</option>
                                <option value="general">General</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Question/Topic</label>
                            <input type="text" name="question" placeholder="e.g., What is your return policy?">
                        </div>
                        <div class="form-group">
                            <label>Answer</label>
                            <textarea name="answer" rows="4" placeholder="Provide a detailed answer..."></textarea>
                        </div>
                        <div class="form-group">
                            <label>Keywords (comma separated)</label>
                            <input type="text" name="keywords" placeholder="return, refund, exchange">
                        </div>
                        <button type="submit" class="btn-primary">Add to Knowledge Base</button>
                    </form>
                </div>

                <div class="knowledge-list">
                    <h3>Your Knowledge Base</h3>
                    <div id="knowledgeItems">
                        <% if (knowledge && knowledge.length > 0) { %>
                            <% knowledge.forEach(item => { %>
                                <div class="knowledge-item">
                                    <div class="knowledge-header">
                                        <strong><%= item.content_type.toUpperCase() %></strong>
                                        <form method="POST" action="/api/chatbot/knowledge/<%= item.id %>?_method=DELETE" style="display:inline;">
                                            <button type="submit" class="delete-btn" onclick="return confirm('Are you sure you want to delete this item?')">Delete</button>
                                        </form>
                                    </div>
                                    <div class="knowledge-question">Q: <%= item.question || 'General Information' %></div>
                                    <div class="knowledge-answer">A: <%= item.answer.substring(0, 200) %><%= item.answer.length > 200 ? '...' : '' %></div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>No knowledge items yet. Add your first FAQ or policy above.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- Embed Script Tab -->
            <div id="embed" class="tab-content <%= tab === 'embed' ? 'active' : '' %>">
                <h2>Embed Script</h2>
                <div class="embed-section">
                    <p>Copy the script below and paste it into your website's HTML code, just before the closing
                        <code></body></code> tag.</p>
                    <div class="code-block">
                        <pre id="embedCode"><%= embedCode || '' %></pre>
                        <button id="copyBtn" class="btn-secondary position-absolute top-0 end-0">Copy</button>
                    </div>

                    <div class="live-preview">
                        <h3>Live Preview</h3>
                        <div id="previewContainer" class="preview-container">
                            <div class="preview-chatbot">
                                <div class="preview-header">Live Preview Mode</div>
                                <div class="preview-content">
                                    <p>Your chatbot will appear here with your custom settings.</p>
                                    <%- embedCode || '' %>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Analytics Tab -->
            <div id="analytics" class="tab-content <%= tab === 'analytics' ? 'active' : '' %>">
                <h2>Conversation Analytics</h2>
                <div id="conversationsList" class="conversations-list">
                    <% if (conversations && conversations.length > 0) { %>
                        <% conversations.forEach(conv => { %>
                            <div class="conversation-item">
                                <div class="conversation-header">
                                    <strong>Session: <%= conv.session_id %></strong>
                                    <small><%= new Date(conv.created_at).toLocaleString() %></small>
                                </div>
                                <div class="conversation-message user">
                                    <strong>Customer:</strong> <%= conv.user_message %>
                                </div>
                                <div class="conversation-message bot">
                                    <strong>Bot:</strong> <%= conv.bot_response %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p>No conversations yet. Your chatbot will start collecting data once embedded.</p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        const copyBtn = document.getElementById('copyBtn');

        copyBtn.addEventListener('click', copyEmbedCode);

        function copyEmbedCode() {
            const code = document.getElementById('embedCode').textContent;
            navigator.clipboard.writeText(code);
            copyBtn.textContent = 'Copied!';
            setTimeout(() => {
                copyBtn.textContent = 'Copy';
            }, 1200);
        }
    </script>
</body>

</html>