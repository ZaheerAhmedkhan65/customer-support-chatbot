<div class="container" data-page="dashboard">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebar"
            class="col-md-3 col-lg-2 d-md-block sidebar collapse show"
            style="min-height: 100vh;">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a data-link class="nav-link <%= !tab || tab === 'settings' ? 'active bg-primary text-white rounded rounded' : 'text-dark' %>"
                            href="/dashboard" style="border-radius: 0;">
                            Chatbot Settings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a data-link class="nav-link <%= tab === 'knowledge' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=knowledge" style="border-radius: 0;">
                            Knowledge Base
                        </a>
                    </li>
                    <li class="nav-item">
                        <a data-link class="nav-link <%= tab === 'embed' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=embed" style="border-radius: 0;">
                            Embed Script
                        </a>
                    </li>
                    <li class="nav-item">
                        <a data-link class="nav-link <%= tab === 'analytics' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=analytics" style="border-radius: 0;">
                            Analytics
                        </a>
                    </li>
                    <li class="nav-item">
                        <a data-link class="nav-link <%= tab === 'billing' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=billing" style="border-radius: 0;">
                            Billing & Usage
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 ">
            <!-- Alert Messages -->
            <% if (typeof success !=='undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"></button>
                        </div>
                        <% } %>

                            <!-- Settings Tab -->
                            <% if (!tab || tab==='settings' ) { %>
                                <div
                                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                    <h1 class="h2">Chatbot Settings</h1>
                                </div>
                                <div class="card border-0  animate__animated animate__fadeInUp">
                                    <div class="card-body">
                                        <form method="POST" action="/api/chatbot/settings">
                                            <input type="hidden" name="_method" value="PUT">
                                            <div class="row mb-3">
                                                <label for="business_name" class="col-sm-3 col-form-label">Business
                                                    Name</label>
                                                <div class="col-sm-9">
                                                    <input type="text" class="form-control" id="business_name"
                                                        name="business_name"
                                                        value="<%= chatbot && chatbot.business_name ? chatbot.business_name : '' %>"
                                                        placeholder="Your Business Name">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="business_email" class="col-sm-3 col-form-label">Business
                                                    Email</label>
                                                <div class="col-sm-9">
                                                    <input type="email" class="form-control" id="business_email"
                                                        name="business_email"
                                                        value="<%= chatbot && chatbot.business_email ? chatbot.business_email : '' %>"
                                                        placeholder="support@yourbusiness.com">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="theme_color" class="col-sm-3 col-form-label">Theme
                                                    Color</label>
                                                <div class="col-sm-9">
                                                    <input type="color" class="form-control form-control-color w-100"
                                                        id="theme_color" name="theme_color"
                                                        value="<%= chatbot && chatbot.theme_color ? chatbot.theme_color : '#3B82F6' %>">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="button_position" class="col-sm-3 col-form-label">Button
                                                    Position</label>
                                                <div class="col-sm-9">
                                                    <select class="form-select" id="button_position"
                                                        name="button_position">
                                                        <option value="right" <%=chatbot &&
                                                            chatbot.button_position==='right' ? 'selected' : '' %>>Right
                                                        </option>
                                                        <option value="left" <%=chatbot &&
                                                            chatbot.button_position==='left' ? 'selected' : '' %>>Left
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="welcome_message" class="col-sm-3 col-form-label">Welcome
                                                    Message</label>
                                                <div class="col-sm-9">
                                                    <textarea class="form-control" id="welcome_message"
                                                        name="welcome_message" rows="3"
                                                        placeholder="Hello! How can I help you today?"><%= chatbot && chatbot.welcome_message ? chatbot.welcome_message : 'Hello! How can I help you today?' %></textarea>
                                                </div>
                                            </div>
                                            <hr>
                                            <h5 class="mb-3">Chatbot Behavior</h5>
                                            <div class="row mb-3">
                                                <label for="default_chatbot_open" class="col-sm-3 col-form-label">Default State</label>
                                                <div class="col-sm-9">
                                                    <select class="form-select" id="default_chatbot_open" name="default_chatbot_open">
                                                        <option value="0" <%=chatbot && chatbot.default_chatbot_open === false ? 'selected' : '' %>>Closed (user must click to open)</option>
                                                        <option value="1" <%=chatbot && chatbot.default_chatbot_open === true ? 'selected' : '' %>>Open automatically</option>
                                                    </select>
                                                    <small class="text-muted">Choose whether the chat window should be open or closed when the page loads.</small>
                                                </div>
                                            </div>
                                            <hr>
                                            <h5 class="mb-3">Emoji Settings</h5>
                                            <div class="row mb-3">
                                                <label for="custom_emojis" class="col-sm-3 col-form-label">Custom Emojis</label>
                                                <div class="col-sm-9">
                                                    <%
                                                        let customEmojisValue = '😊, 👍, ❤️, 😂, 🎉, 🤔, 👋, 🙏';
                                                        if (chatbot && chatbot.custom_emojis) {
                                                            try {
                                                                const parsed = JSON.parse(chatbot.custom_emojis);
                                                                if (Array.isArray(parsed)) {
                                                                    customEmojisValue = parsed.join(', ');
                                                                }
                                                            } catch (e) {}
                                                        }
                                                    %>
                                                    <input type="text" class="form-control" id="custom_emojis" name="custom_emojis"
                                                        value="<%= customEmojisValue %>"
                                                        placeholder="😊, 👍, ❤️, 😂, 🎉, 🤔, 👋, 🙏">
                                                    <small class="text-muted">Comma-separated emoji list. Leave empty to hide emoji button.</small>
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="show_emoji_toggle" class="col-sm-3 col-form-label">Show Emoji Button</label>
                                                <div class="col-sm-9">
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="show_emoji_toggle" name="show_emoji_toggle" <%=chatbot && chatbot.show_emoji_toggle === false ? '' : 'checked' %>>
                                                        <label class="form-check-label" for="show_emoji_toggle">Enable emoji picker</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <hr>
                                            <h5 class="mb-3">Quick Replies</h5>
                                            <div class="row mb-3">
                                                <label for="custom_quick_replies" class="col-sm-3 col-form-label">Quick Replies</label>
                                                <div class="col-sm-9">
                                                    <%
                                                        let quickRepliesValue = 'Help\nPricing\nContact\nFAQ';
                                                        if (chatbot && chatbot.custom_quick_replies) {
                                                            try {
                                                                const parsed = JSON.parse(chatbot.custom_quick_replies);
                                                                if (Array.isArray(parsed) && parsed.length > 0) {
                                                                    quickRepliesValue = parsed.join('\n');
                                                                }
                                                            } catch (e) {}
                                                        }
                                                    %>
                                                    <textarea class="form-control" id="custom_quick_replies" name="custom_quick_replies" rows="3"
                                                        placeholder="Enter one quick reply per line"><%= quickRepliesValue %></textarea>
                                                    <small class="text-muted">One quick reply per line. These appear as clickable buttons below the chat.</small>
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="show_quick_replies" class="col-sm-3 col-form-label">Show Quick Replies</label>
                                                <div class="col-sm-9">
                                                    <div class="form-check form-switch">
                                                        <input class="form-check-input" type="checkbox" id="show_quick_replies" name="show_quick_replies" <%=chatbot && chatbot.show_quick_replies === false ? '' : 'checked' %>>
                                                        <label class="form-check-label" for="show_quick_replies">Show quick reply buttons</label>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                                <button type="submit" class="btn btn-primary">Save Settings</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Knowledge Base Tab -->

                                    <!-- Knowledge Base Tab -->
                                    <% if (tab==='knowledge' ) { %>
                                        <div
                                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                            <h1 class="h2">Knowledge Base</h1>
                                        </div>

                                        <!-- Add New Content Manually -->
                                        <div class="card mb-4 animate__animated animate__fadeInUp">
                                            <div
                                                class="card-header bg-primary text-white">
                                                <h5 class="mb-0">Add New Content Manually</h5>
                                            </div>
                                            <div class="card-body">
                                                <form method="POST" action="/api/chatbot/knowledge">
                                                    <div class="row mb-3">
                                                        <label for="content_type"
                                                            class="col-sm-3 col-form-label">Content Type</label>
                                                        <div class="col-sm-9">
                                                            <select class="form-select" id="content_type"
                                                                name="content_type">
                                                                <option value="faq">FAQ</option>
                                                                <option value="policy">Policy</option>
                                                                <option value="delivery">Delivery Info</option>
                                                                <option value="refund">Refund Policy</option>
                                                                <option value="product">Product Details</option>
                                                                <option value="general">General</option>
                                                                <option value="shipping">Shipping Information</option>
                                                                <option value="pricing">Pricing & Plans</option>
                                                                <option value="account">Account Management</option>
                                                                <option value="technical">Technical Support</option>
                                                                <option value="billing">Billing & Invoicing</option>
                                                                <option value="security">Security & Privacy</option>
                                                                <option value="troubleshooting">Troubleshooting</option>
                                                                <option value="returns">Returns & Exchanges</option>
                                                                <option value="warranty">Warranty Information</option>
                                                                <option value="installation">Installation & Setup</option>
                                                                <option value="integration">Integrations & API</option>
                                                                <option value="compliance">Compliance & Legal</option>
                                                                <option value="training">Training & Onboarding</option>
                                                                <option value="maintenance">Maintenance & Upkeep</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="question"
                                                            class="col-sm-3 col-form-label">Question/Topic</label>
                                                        <div class="col-sm-9">
                                                            <input type="text" class="form-control" id="question"
                                                                name="question"
                                                                placeholder="e.g., What is your return policy?">
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="answer"
                                                            class="col-sm-3 col-form-label">Answer</label>
                                                        <div class="col-sm-9">
                                                            <textarea class="form-control" id="answer" name="answer"
                                                                rows="4"
                                                                placeholder="Provide a detailed answer..."></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="keywords"
                                                            class="col-sm-3 col-form-label">Keywords</label>
                                                        <div class="col-sm-9">
                                                            <input type="text" class="form-control" id="keywords"
                                                                name="keywords"
                                                                placeholder="Keywords auto-generated from answer">
                                                            <div class="form-text mt-1">Keywords are automatically generated
                                                                from the answer as you type.</div>
                                                        </div>
                                                    </div>
                                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                                        <button type="submit" class="btn btn-primary">Add to Knowledge
                                                            Base</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>

                                        <!-- Crawl Website -->
                                        <div class="card mb-4 animate__animated animate__fadeInUp">
                                            <div class="card-header bg-success text-white">
                                                <h5 class="mb-0"><i class="bi bi-globe2"></i> Import from Website</h5>
                                            </div>
                                            <div class="card-body">
                                                <p class="text-muted">Enter a website URL to automatically extract useful content and add it to your knowledge base.</p>
                                                <div class="input-group mb-3">
                                                    <input type="url" class="form-control" id="crawlUrl"
                                                        placeholder="https://example.com" value="">
                                                    <button class="btn btn-success" type="button" id="crawlBtn">
                                                        <i class="bi bi-search"></i> Crawl & Extract
                                                    </button>
                                                </div>
                                                <div id="crawlProgress" class="d-none">
                                                    <div class="d-flex align-items-center mb-2">
                                                        <div class="spinner-border spinner-border-sm text-success me-2" role="status">
                                                            <span class="visually-hidden">Loading...</span>
                                                        </div>
                                                        <span id="crawlStatus">Crawling website...</span>
                                                    </div>
                                                    <div class="progress" style="height: 6px;">
                                                        <div class="progress-bar progress-bar-striped progress-bar-animated bg-success" id="crawlProgressBar" style="width: 0%"></div>
                                                    </div>
                                                </div>
                                                <div id="crawlResults" class="d-none">
                                                    <hr>
                                                    <h6 class="mb-3">Discovered Entries</h6>
                                                    <div id="crawlEntriesList"></div>
                                                    <div class="d-grid mt-3">
                                                        <button class="btn btn-success" id="importCrawledBtn" disabled>
                                                            <i class="bi bi-download"></i> Import Selected
                                                        </button>
                                                    </div>
                                                </div>
                                                <div id="crawlError" class="alert alert-danger d-none mt-3"></div>
                                            </div>
                                        </div>

                                        <div class="card border-0 animate__animated animate__fadeInUp">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h5 class="mb-0">Your Knowledge Base</h5>
                                                <div>
                                                    <span class="badge bg-primary me-2">
                                                        <%= knowledge ? knowledge.length : 0 %> entries
                                                    </span>
                                                    <button class="btn btn-sm btn-outline-danger" id="bulkDeleteToggle" type="button">
                                                        <i class="bi bi-trash"></i> Bulk Delete
                                                    </button>
                                                </div>
                                            </div>
                                            <div id="bulkDeleteBar" class="d-none p-2 bg-light border mb-3 d-flex justify-content-between align-items-center">
                                                <span class="text-muted">Select items to delete</span>
                                                <button class="btn btn-sm btn-danger" id="deleteSelectedBtn" disabled>Delete Selected</button>
                                            </div>
                                            <div class="card-body p-0">
                                                <% if (knowledge && knowledge.length> 0) { %>
                                                    <div class="list-group" id="knowledgeList">
                                                        <% knowledge.forEach(item=> { %>
                                                            <div class="list-group-item list-group-item-action" data-id="<%= item.id %>">
                                                                <div
                                                                    class="d-flex w-100 justify-content-between align-items-start">
                                                                    <div class="flex-grow-1">
                                                                        <div class="form-check mb-2 bulk-check-wrap d-none">
                                                                            <input class="form-check-input bulk-check" type="checkbox" value="<%= item.id %>">
                                                                        </div>
                                                                        <div class="mb-2">
                                                                            <span class="badge bg-secondary me-2">
                                                                                <%= item.content_type.toUpperCase() %>
                                                                            </span>
                                                                            <strong>
                                                                                <%= item.question
                                                                                    || 'General Information' %>
                                                                            </strong>
                                                                        </div>
                                                                        <p class="mb-2 text-muted">
                                                                            <%= item.answer.substring(0, 200) %>
                                                                                <%= item.answer.length> 200 ? '...' : ''
                                                                                    %>
                                                                        </p>
                                                                        <% if (item.keywords) { %>
                                                                            <small class="text-muted">
                                                                                <i class="bi bi-tags"></i>
                                                                                <% const
                                                                                    keywords=item.keywords.split(',');
                                                                                    keywords.forEach((kw, i)=> { %>
                                                                                    <span
                                                                                        class="badge bg-light text-dark me-1">
                                                                                        <%= kw.trim() %>
                                                                                    </span>
                                                                                    <% }); %>
                                                                            </small>
                                                                            <% } %>
                                                                    </div>
                                                                    <div class="ms-2">
                                                                        <div class="dropdown">
                                                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                                                                <i class="bi bi-three-dots-vertical"></i>
                                                                            </button>
                                                                            <ul class="dropdown-menu dropdown-menu-end">
                                                                                <li><button class="dropdown-item show-item-btn" type="button" data-id="<%= item.id %>" data-type="<%= item.content_type %>" data-question="<%= item.question %>" data-answer="<%= item.answer %>" data-keywords="<%= item.keywords || '' %>"><i class="bi bi-eye me-2"></i>Show</button></li>
                                                                                <li><button class="dropdown-item edit-btn" type="button" data-id="<%= item.id %>" data-type="<%= item.content_type %>" data-question="<%= item.question %>" data-answer="<%= item.answer %>" data-keywords="<%= item.keywords || '' %>"><i class="bi bi-pencil me-2"></i>Edit</button></li>
                                                                                <li><hr class="dropdown-divider"></li>
                                                                                <li><button class="dropdown-item text-danger delete-trigger-btn" type="button" data-id="<%= item.id %>"><i class="bi bi-trash me-2"></i>Delete</button></li>
                                                                            </ul>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <% }); %>
                                                    </div>
                                                    <% } else { %>
                                                        <div class="text-center py-5">
                                                            <i class="bi bi-journal-x display-4 text-muted"></i>
                                                            <p class="text-muted mt-3">No knowledge items yet.</p>
                                                            <p class="text-muted small">Add your first FAQ, policy, or
                                                                use a template to get started.</p>
                                                        </div>
                                                        <% } %>
                                            </div>
                                        </div>
                                        <% } %>

                                            <!-- Embed Script Tab -->
                                            <% if (tab==='embed' ) { %>
                                                <div
                                                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                                    <h1 class="h2">Embed Script</h1>
                                                </div>

                                                <div class="card border-0  mb-4 animate__animated animate__fadeInUp">
                                                    <div class="card-body">
                                                        <p class="lead">Copy the script below and paste it into your
                                                            website's HTML code, just before the body closing tag.
                                                        </p>
                                                        <div class="position-relative">
                                                            <pre class="bg-dark text-light p-3 rounded" id="embedCode"
                                                                style="overflow-x: auto;"><%= embedCode || '' %></pre>
                                                            <button id="copyBtn"
                                                                class="btn btn-sm btn-outline-light position-absolute top-0 end-0 m-2">
                                                                Copy
                                                            </button>
                                                        </div>
                                                        <ol class="ps-3 py-3 lead">
                                                            <li class="mb-1">Copy the embed script</li>
                                                            <li class="mb-1">Paste it before the closing body tag</li>
                                                            <li class="mb-1">Reload your website</li>
                                                        </ol>
                                                    </div>
                                                </div>
                                                    <% } %>

                                                        <!-- Analytics Tab -->
                                                        <% if (tab==='analytics' ) { %>
                                                            <div
                                                                class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                                                <h1 class="h2">Conversation Analytics</h1>
                                                            </div>

                                                            <!-- Analytics Summary Cards -->
                                                            <div class="row g-4 mb-4 animate__animated animate__fadeInUp">
                                                                <div class="col-md-3">
                                                                    <div class="card border-0 shadow-sm h-100">
                                                                        <div class="card-body text-center">
                                                                            <h3 class="h2 mb-0" id="totalConversations">0</h3>
                                                                            <p class="text-muted mb-0">Total Conversations</p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <div class="card border-0 shadow-sm h-100">
                                                                        <div class="card-body text-center">
                                                                            <h3 class="h2 mb-0" id="totalSessions">0</h3>
                                                                            <p class="text-muted mb-0">Unique Sessions</p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <div class="card border-0 shadow-sm h-100">
                                                                        <div class="card-body text-center">
                                                                            <h3 class="h2 mb-0" id="todayConversations">0</h3>
                                                                            <p class="text-muted mb-0">Today</p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                                <div class="col-md-3">
                                                                    <div class="card border-0 shadow-sm h-100">
                                                                        <div class="card-body text-center">
                                                                            <h3 class="h2 mb-0" id="avgMessagesPerSession">0</h3>
                                                                            <p class="text-muted mb-0">Avg Messages/Session</p>
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>

                                                            <!-- Chart Card -->
                                                            <div class="card border-0 shadow-sm mb-4 animate__animated animate__fadeInUp">
                                                                <div class="card-body">
                                                                    <h5 class="card-title mb-4">Conversation Trend (Last 7 Days)</h5>
                                                                    <canvas id="conversationChart" height="100"></canvas>
                                                                </div>
                                                            </div>

                                                            <!-- Conversations List -->
                                                            <div class="card border-0 shadow-sm animate__animated animate__fadeInUp">
                                                                <div class="card-body">
                                                                    <h5 class="card-title mb-4">Recent Conversations</h5>
                                                                    
                                                                    <div id="conversationsContainer">
                                                                        <!-- Conversations will be loaded here -->
                                                                    </div>
                                                                    
                                                                    <div id="loadingIndicator" class="text-center py-3" style="display: none;">
                                                                        <div class="spinner-border text-primary" role="status">
                                                                            <span class="visually-hidden">Loading...</span>
                                                                        </div>
                                                                    </div>
                                                                    
                                                                    <div id="noMoreData" class="text-center py-3 text-muted" style="display: none;">
                                                                        <p class="mb-0">No more conversations to load</p>
                                                                    </div>
                                                                    
                                                                    <div id="noConversations" class="text-center py-5">
                                                                        <i class="bi bi-chat-square-text display-4 text-muted"></i>
                                                                        <p class="text-muted mt-3">No conversations yet. Your chatbot will start collecting data once embedded.</p>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                 <!-- Billing & Usage Tab -->
                                                                 <% if (tab==='billing' ) { %>
                                                                     <div
                                                                         class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                                                         <h1 class="h2">Billing & Usage</h1>
                                                                     </div>

                                                                     <!-- Usage Overview Card -->
                                                                     <div class="card border-0 mb-4 animate__animated animate__fadeInUp">
                                                                         <div class="card-body">
                                                                             <h5 class="card-title mb-4">Current Month Usage</h5>
                                                                             <div class="row g-4">
                                                                                 <div class="col-md-6">
                                                                                     <div class="p-3 bg-light rounded">
                                                                                         <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                             <span class="text-muted">Conversations</span>
                                                                                             <span class="badge bg-primary" id="conversationBadge">Loading...</span>
                                                                                         </div>
                                                                                         <div class="progress" style="height: 10px;">
                                                                                             <div class="progress-bar bg-primary" id="conversationProgress" role="progressbar" style="width: 0%"></div>
                                                                                         </div>
                                                                                         <small class="text-muted" id="conversationDetails">0 / 1,000</small>
                                                                                     </div>
                                                                                 </div>
                                                                                 <div class="col-md-6">
                                                                                     <div class="p-3 bg-light rounded">
                                                                                         <div class="d-flex justify-content-between align-items-center mb-2">
                                                                                             <span class="text-muted">Knowledge Base Items</span>
                                                                                             <span class="badge bg-success" id="kbBadge">Loading...</span>
                                                                                         </div>
                                                                                         <div class="progress" style="height: 10px;">
                                                                                             <div class="progress-bar bg-success" id="kbProgress" role="progressbar" style="width: 0%"></div>
                                                                                         </div>
                                                                                         <small class="text-muted" id="kbDetails">0 / 50</small>
                                                                                     </div>
                                                                                 </div>
                                                                             </div>
                                                                         </div>
                                                                     </div>

                                                                      <!-- Current Plan Card -->
                                                                      <div class="card border-0 mb-4 animate__animated animate__fadeInUp">
                                                                          <div class="card-body">
                                                                              <h5 class="card-title mb-4">Current Plan</h5>
                                                                              <div class="row align-items-center">
                                                                                  <div class="col-md-8">
                                                                                      <div class="d-flex align-items-center">
                                                                                          <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center me-3" style="width: 60px; height: 60px;">
                                                                                              <span class="h4 mb-0" id="planInitial">S</span>
                                                                                          </div>
                                                                                          <div>
                                                                                              <h4 class="mb-1" id="currentPlanName">Starter</h4>
                                                                                              <p class="text-muted mb-0" id="currentPlanPrice">Free</p>
                                                                                          </div>
                                                                                      </div>
                                                                                  </div>
                                                                                  <div class="col-md-4 text-md-end mt-3 mt-md-0">
                                                                                      <span class="badge bg-success" id="planStatus">Active</span>
                                                                                  </div>
                                                                              </div>
                                                                          </div>
                                                                      </div>

                                                                      <!-- Upgrade Options -->
                                                                      <div class="card border-0 mb-4 animate__animated animate__fadeInUp">
                                                                          <div class="card-body">
                                                                              <h5 class="card-title mb-4">Upgrade Your Plan</h5>
                                                                              <div class="row g-4" id="subscriptionPlans">
                                                                                  <!--Show pricing cards-->
                                                                              </div>
                                                                          </div>
                                                                      </div>

                                                                      <!-- Cancel Subscription -->
                                                                      <div class="card border-0 mb-4 animate__animated animate__fadeInUp">
                                                                          <div class="card-body">
                                                                              <h5 class="card-title mb-4 text-danger">Danger Zone</h5>
                                                                              <div class="alert alert-warning d-flex align-items-center" role="alert">
                                                                                  <div class="flex-grow-1">
                                                                                      <strong>Cancel Subscription</strong>
                                                                                      <p class="mb-0 small">If you cancel your subscription, you will be downgraded to the free Starter plan at the end of your current billing period. Your chatbot will continue to work with limited features.</p>
                                                                                  </div>
                                                                                  <button class="btn btn-outline-danger btn-sm ms-3" id="cancelBtn" style="white-space: nowrap;">Cancel Subscription</button>
                                                                              </div>
                                                                          </div>
                                                                      </div>
                                                                      <% } %>

                                                                         <!-- Knowledge Base Loading State -->
                                                                <% if (tab==='knowledge' ) { %>
                                                                    <div id="knowledgeLoading"
                                                                        class="card border-0  animate__animated animate__fadeInUp"
                                                                        style="display: none;">
                                                                        <div class="card-body">
                                                                            <div class="skeleton skeleton-title mb-4">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text medium mb-3">
                                                                            </div>
                                                                            <div class="skeleton skeleton-text mb-3">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text short mb-4">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
        </main>
        <% if (tab==='knowledge' ) { %>
            <!-- Show Knowledge Modal -->
            <div class="modal fade" id="showModal" tabindex="-1" aria-labelledby="showModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="showModalLabel">Knowledge Base Detail</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p><span class="badge bg-secondary me-2" id="showType"></span><strong id="showQuestion"></strong></p>
                            <hr>
                            <p class="text-muted" id="showAnswer" style="white-space: pre-line;"></p>
                            <hr>
                            <small class="text-muted"><i class="bi bi-tags"></i> <span id="showKeywords"></span></small>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Edit Knowledge Modal -->
            <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="editModalLabel">Edit Knowledge Base Entry</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form method="POST" action="/api/chatbot/knowledge/" id="editForm">
                            <input type="hidden" name="_method" value="PUT">
                            <input type="hidden" id="editId" name="id">
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label for="edit_content_type" class="form-label">Content Type</label>
                                    <select class="form-select" id="edit_content_type" name="content_type">
                                        <option value="faq">FAQ</option>
                                        <option value="policy">Policy</option>
                                        <option value="delivery">Delivery Info</option>
                                        <option value="refund">Refund Policy</option>
                                        <option value="product">Product Details</option>
                                        <option value="general">General</option>
                                        <option value="shipping">Shipping Information</option>
                                        <option value="pricing">Pricing & Plans</option>
                                        <option value="account">Account Management</option>
                                        <option value="technical">Technical Support</option>
                                        <option value="billing">Billing & Invoicing</option>
                                        <option value="security">Security & Privacy</option>
                                        <option value="troubleshooting">Troubleshooting</option>
                                        <option value="returns">Returns & Exchanges</option>
                                        <option value="warranty">Warranty Information</option>
                                        <option value="installation">Installation & Setup</option>
                                        <option value="integration">Integrations & API</option>
                                        <option value="compliance">Compliance & Legal</option>
                                        <option value="training">Training & Onboarding</option>
                                        <option value="maintenance">Maintenance & Upkeep</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_question" class="form-label">Question/Topic</label>
                                    <input type="text" class="form-control" id="edit_question" name="question" required>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_answer" class="form-label">Answer</label>
                                    <textarea class="form-control" id="edit_answer" name="answer" rows="5"
                                        required></textarea>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_keywords" class="form-label">Keywords</label>
                                    <input type="text" class="form-control" id="edit_keywords" name="keywords"
                                        placeholder="Comma separated keywords">
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <% } %>
    </div>
</div>
