<div class="container">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebar" class="col-md-3 col-lg-2 d-md-block sidebar collapse show animate__animated animate__fadeInLeft" style="min-height: 100vh;">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link <%= !tab || tab === 'settings' ? 'active bg-primary text-white rounded rounded' : 'text-dark' %>" 
                           href="/dashboard" 
                           style="border-radius: 0;">
                            Chatbot Settings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'knowledge' ? 'active bg-primary text-white rounded' : 'text-dark' %>" 
                           href="/dashboard?tab=knowledge" 
                           style="border-radius: 0;">
                           Knowledge Base
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'embed' ? 'active bg-primary text-white rounded' : 'text-dark' %>" 
                           href="/dashboard?tab=embed" 
                           style="border-radius: 0;">
                            Embed Script
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'analytics' ? 'active bg-primary text-white rounded' : 'text-dark' %>" 
                           href="/dashboard?tab=analytics" 
                           style="border-radius: 0;">
                            Analytics
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 animate__animated animate__fadeInRight">
            <!-- Alert Messages -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <%= error %>
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            <% } %>

            <!-- Settings Tab -->
            <% if (!tab || tab === 'settings') { %>
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                <h1 class="h2">Chatbot Settings</h1>
            </div>
            <div class="card border-0  animate__animated animate__fadeInUp">
                <div class="card-body">
                    <form method="POST" action="/api/chatbot/settings">
                        <input type="hidden" name="_method" value="PUT">
                        <div class="row mb-3">
                            <label for="business_name" class="col-sm-3 col-form-label">Business Name</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="business_name" name="business_name" 
                                       value="<%= chatbot && chatbot.business_name ? chatbot.business_name : '' %>"
                                       placeholder="Your Business Name">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="business_email" class="col-sm-3 col-form-label">Business Email</label>
                            <div class="col-sm-9">
                                <input type="email" class="form-control" id="business_email" name="business_email" 
                                       value="<%= chatbot && chatbot.business_email ? chatbot.business_email : '' %>"
                                       placeholder="support@yourbusiness.com">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="theme_color" class="col-sm-3 col-form-label">Theme Color</label>
                            <div class="col-sm-9">
                                <input type="color" class="form-control form-control-color w-100" id="theme_color" name="theme_color" 
                                       value="<%= chatbot && chatbot.theme_color ? chatbot.theme_color : '#3B82F6' %>">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="button_position" class="col-sm-3 col-form-label">Button Position</label>
                            <div class="col-sm-9">
                                <select class="form-select" id="button_position" name="button_position">
                                    <option value="right" <%= chatbot && chatbot.button_position === 'right' ? 'selected' : '' %>>Right</option>
                                    <option value="left" <%= chatbot && chatbot.button_position === 'left' ? 'selected' : '' %>>Left</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="welcome_message" class="col-sm-3 col-form-label">Welcome Message</label>
                            <div class="col-sm-9">
                                <textarea class="form-control" id="welcome_message" name="welcome_message" rows="3" 
                                          placeholder="Hello! How can I help you today?"><%= chatbot && chatbot.welcome_message ? chatbot.welcome_message : 'Hello! How can I help you today?' %></textarea>
                            </div>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary">Save Settings</button>
                        </div>
                    </form>
                </div>
            </div>
            <% } %>

            <!-- Knowledge Base Tab -->
            <% if (tab === 'knowledge') { %>
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                <h1 class="h2">Knowledge Base</h1>
            </div>
            
            <div class="card  mb-4 animate__animated animate__fadeInUp">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Add New Content</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="/api/chatbot/knowledge">
                        <div class="row mb-3">
                            <label for="content_type" class="col-sm-3 col-form-label">Content Type</label>
                            <div class="col-sm-9">
                                <select class="form-select" id="content_type" name="content_type">
                                    <option value="faq">FAQ</option>
                                    <option value="policy">Policy</option>
                                    <option value="delivery">Delivery Info</option>
                                    <option value="refund">Refund Policy</option>
                                    <option value="product">Product Details</option>
                                    <option value="general">General</option>
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="question" class="col-sm-3 col-form-label">Question/Topic</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="question" name="question" 
                                       placeholder="e.g., What is your return policy?">
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="answer" class="col-sm-3 col-form-label">Answer</label>
                            <div class="col-sm-9">
                                <textarea class="form-control" id="answer" name="answer" rows="4" 
                                          placeholder="Provide a detailed answer..."></textarea>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label for="keywords" class="col-sm-3 col-form-label">Keywords</label>
                            <div class="col-sm-9">
                                <input type="text" class="form-control" id="keywords" name="keywords" 
                                       placeholder="return, refund, exchange">
                                <div class="form-text">Comma separated keywords</div>
                            </div>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary">Add to Knowledge Base</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card border-0 animate__animated animate__fadeInUp">
                <h5>Your Knowledge Base</h5>
                <div class="card-body p-0">
                    <% if (knowledge && knowledge.length > 0) { %>
                        <div class="list-group">
                            <% knowledge.forEach(item => { %>
                                <div class="list-group-item list-group-item-action">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <div>
                                            <span class="badge bg-secondary me-2"><%= item.content_type.toUpperCase() %></span>
                                            <strong><%= item.question || 'General Information' %></strong>
                                        </div>
                                        <form method="POST" action="/api/chatbot/knowledge/<%= item.id %>?_method=DELETE" style="display:inline;">
                                            <button type="submit" class="btn btn-sm btn-outline-danger" 
                                                    onclick="return confirm('Are you sure you want to delete this item?')">
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                    <p class="mb-1 mt-2 text-muted"><%= item.answer.substring(0, 200) %><%= item.answer.length > 200 ? '...' : '' %></p>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center">No knowledge items yet. Add your first FAQ or policy above.</p>
                    <% } %>
                </div>
            </div>
            <% } %>

            <!-- Embed Script Tab -->
            <% if (tab === 'embed') { %>
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                <h1 class="h2">Embed Script</h1>
            </div>
            
            <div class="card border-0  mb-4 animate__animated animate__fadeInUp">
                <div class="card-body">
                    <p class="lead">Copy the script below and paste it into your website's HTML code, just before the closing <code></body></code> tag.</p>
                    
                    <div class="position-relative">
                        <pre class="bg-dark text-light p-3 rounded" id="embedCode" style="overflow-x: auto;"><%= embedCode || '' %></pre>
                        <button id="copyBtn" class="btn btn-sm btn-outline-light position-absolute top-0 end-0 m-2">
                            Copy
                        </button>
                    </div>
                </div>
            </div>

            <%- embedCode || '' %>
            <% } %>

            <!-- Analytics Tab -->
            <% if (tab === 'analytics') { %>
            <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                <h1 class="h2">Conversation Analytics</h1>
            </div>
            
            <div class="card border-0  animate__animated animate__fadeInUp">
                <div class="card-body">
                    <% if (typeof conversations === 'undefined' || conversations === null) { %>
                        <!-- Skeleton Loader for Analytics -->
                        <div class="skeleton-loader">
                            <div class="skeleton skeleton-title mb-4"></div>
                            <div class="skeleton skeleton-text medium mb-3"></div>
                            <div class="skeleton skeleton-text mb-3"></div>
                            <div class="skeleton skeleton-text short mb-4"></div>
                            <div class="skeleton skeleton-title mb-4"></div>
                            <div class="skeleton skeleton-text medium mb-3"></div>
                            <div class="skeleton skeleton-text mb-3"></div>
                        </div>
                    <% } else if (conversations && conversations.length > 0) { %>
                        <div class="list-group">
                            <% conversations.forEach(conv => { %>
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between mb-2">
                                        <small class="text-muted">
                                            <strong>Session:</strong> <%= conv.session_id %>
                                        </small>
                                        <small class="text-muted">
                                            <%= new Date(conv.created_at).toLocaleString() %>
                                        </small>
                                    </div>
                                    <div class="mb-2">
                                        <span class="badge bg-primary">Customer:</span>
                                        <span class="ms-2"><%= conv.user_message %></span>
                                    </div>
                                    <div>
                                        <span class="badge bg-success">Bot:</span>
                                        <span class="ms-2"><%= conv.bot_response %></span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <p class="text-muted text-center">No conversations yet. Your chatbot will start collecting data once embedded.</p>
                    <% } %>
                </div>
            </div>
            <% } %>

            <!-- Knowledge Base Loading State -->
            <% if (tab === 'knowledge') { %>
            <div id="knowledgeLoading" class="card border-0  animate__animated animate__fadeInUp" style="display: none;">
                <div class="card-body">
                    <div class="skeleton skeleton-title mb-4"></div>
                    <div class="skeleton skeleton-text medium mb-3"></div>
                    <div class="skeleton skeleton-text mb-3"></div>
                    <div class="skeleton skeleton-text short mb-4"></div>
                </div>
            </div>
            <% } %>
        </main>
    </div>
</div>

<script>
    const copyBtn = document.getElementById('copyBtn');

    if (copyBtn) {
        copyBtn.addEventListener('click', copyEmbedCode);
    }

    function copyEmbedCode() {
        const code = document.getElementById('embedCode').textContent;
        navigator.clipboard.writeText(code);
        copyBtn.textContent = 'Copied!';
        copyBtn.classList.remove('btn-outline-light');
        copyBtn.classList.add('btn-success');
        setTimeout(() => {
            copyBtn.textContent = 'Copy';
            copyBtn.classList.remove('btn-success');
            copyBtn.classList.add('btn-outline-light');
        }, 1200);
    }
</script>
