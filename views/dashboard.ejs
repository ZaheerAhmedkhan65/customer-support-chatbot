<div class="container">
    <div class="row">
        <!-- Sidebar -->
        <nav id="sidebar"
            class="col-md-3 col-lg-2 d-md-block sidebar collapse show animate__animated animate__fadeInLeft"
            style="min-height: 100vh;">
            <div class="position-sticky pt-3">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link <%= !tab || tab === 'settings' ? 'active bg-primary text-white rounded rounded' : 'text-dark' %>"
                            href="/dashboard" style="border-radius: 0;">
                            Chatbot Settings
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'knowledge' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=knowledge" style="border-radius: 0;">
                            Knowledge Base
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'embed' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=embed" style="border-radius: 0;">
                            Embed Script
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link <%= tab === 'analytics' ? 'active bg-primary text-white rounded' : 'text-dark' %>"
                            href="/dashboard?tab=analytics" style="border-radius: 0;">
                            Analytics
                        </a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Main Content -->
        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4 animate__animated animate__fadeInRight">
            <!-- Alert Messages -->
            <% if (typeof success !=='undefined' && success) { %>
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <%= success %>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
                <% } %>
                    <% if (typeof error !=='undefined' && error) { %>
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <%= error %>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"
                                    aria-label="Close"></button>
                        </div>
                        <% } %>

                            <!-- Settings Tab -->
                            <% if (!tab || tab==='settings' ) { %>
                                <div
                                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                    <h1 class="h2">Chatbot Settings</h1>
                                </div>
                                <div class="card border-0  animate__animated animate__fadeInUp">
                                    <div class="card-body">
                                        <form method="POST" action="/api/chatbot/settings">
                                            <input type="hidden" name="_method" value="PUT">
                                            <div class="row mb-3">
                                                <label for="business_name" class="col-sm-3 col-form-label">Business
                                                    Name</label>
                                                <div class="col-sm-9">
                                                    <input type="text" class="form-control" id="business_name"
                                                        name="business_name"
                                                        value="<%= chatbot && chatbot.business_name ? chatbot.business_name : '' %>"
                                                        placeholder="Your Business Name">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="business_email" class="col-sm-3 col-form-label">Business
                                                    Email</label>
                                                <div class="col-sm-9">
                                                    <input type="email" class="form-control" id="business_email"
                                                        name="business_email"
                                                        value="<%= chatbot && chatbot.business_email ? chatbot.business_email : '' %>"
                                                        placeholder="support@yourbusiness.com">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="theme_color" class="col-sm-3 col-form-label">Theme
                                                    Color</label>
                                                <div class="col-sm-9">
                                                    <input type="color" class="form-control form-control-color w-100"
                                                        id="theme_color" name="theme_color"
                                                        value="<%= chatbot && chatbot.theme_color ? chatbot.theme_color : '#3B82F6' %>">
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="button_position" class="col-sm-3 col-form-label">Button
                                                    Position</label>
                                                <div class="col-sm-9">
                                                    <select class="form-select" id="button_position"
                                                        name="button_position">
                                                        <option value="right" <%=chatbot &&
                                                            chatbot.button_position==='right' ? 'selected' : '' %>>Right
                                                        </option>
                                                        <option value="left" <%=chatbot &&
                                                            chatbot.button_position==='left' ? 'selected' : '' %>>Left
                                                        </option>
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="row mb-3">
                                                <label for="welcome_message" class="col-sm-3 col-form-label">Welcome
                                                    Message</label>
                                                <div class="col-sm-9">
                                                    <textarea class="form-control" id="welcome_message"
                                                        name="welcome_message" rows="3"
                                                        placeholder="Hello! How can I help you today?"><%= chatbot && chatbot.welcome_message ? chatbot.welcome_message : 'Hello! How can I help you today?' %></textarea>
                                                </div>
                                            </div>
                                            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                                <button type="submit" class="btn btn-primary">Save Settings</button>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <% } %>

                                    <!-- Knowledge Base Tab -->
                                    <% if (tab==='knowledge' ) { %>
                                        <div
                                            class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                            <h1 class="h2">Knowledge Base</h1>
                                        </div>

                                        <!-- Quick Actions -->
                                        <div class="row mb-4 animate__animated animate__fadeInUp">
                                            <div class="col-12">
                                                <div class="card border-0">
                                                    <div class="card-body">
                                                        <div class="d-flex flex-wrap gap-2">
                                                            <button class="btn btn-outline-primary"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#bulkImportModal">
                                                                <i class="bi bi-upload"></i> Bulk Import
                                                            </button>
                                                            <button class="btn btn-outline-primary"
                                                                data-bs-toggle="modal"
                                                                data-bs-target="#aiGenerateModal">
                                                                <i class="bi bi-magic"></i> AI Generate
                                                            </button>
                                                            <button class="btn btn-outline-primary"
                                                                data-bs-toggle="modal" data-bs-target="#templatesModal">
                                                                <i class="bi bi-file-earmark-text"></i> Use Template
                                                            </button>
                                                            <button class="btn btn-outline-primary"
                                                                data-bs-toggle="collapse" data-bs-target="#manualForm">
                                                                <i class="bi bi-pencil"></i> Manual Entry
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Manual Entry Form (Collapsible) -->
                                        <div class="card mb-4 collapse show animate__animated animate__fadeInUp"
                                            id="manualForm">
                                            <div
                                                class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                                                <h5 class="mb-0">Add New Content Manually</h5>
                                                <button type="button" class="btn-close btn-close-white"
                                                    data-bs-toggle="collapse" data-bs-target="#manualForm"></button>
                                            </div>
                                            <div class="card-body">
                                                <form method="POST" action="/api/chatbot/knowledge">
                                                    <div class="row mb-3">
                                                        <label for="content_type"
                                                            class="col-sm-3 col-form-label">Content Type</label>
                                                        <div class="col-sm-9">
                                                            <select class="form-select" id="content_type"
                                                                name="content_type">
                                                                <option value="faq">FAQ</option>
                                                                <option value="policy">Policy</option>
                                                                <option value="delivery">Delivery Info</option>
                                                                <option value="refund">Refund Policy</option>
                                                                <option value="product">Product Details</option>
                                                                <option value="general">General</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="question"
                                                            class="col-sm-3 col-form-label">Question/Topic</label>
                                                        <div class="col-sm-9">
                                                            <input type="text" class="form-control" id="question"
                                                                name="question"
                                                                placeholder="e.g., What is your return policy?">
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="answer"
                                                            class="col-sm-3 col-form-label">Answer</label>
                                                        <div class="col-sm-9">
                                                            <textarea class="form-control" id="answer" name="answer"
                                                                rows="4"
                                                                placeholder="Provide a detailed answer..."></textarea>
                                                        </div>
                                                    </div>
                                                    <div class="row mb-3">
                                                        <label for="keywords"
                                                            class="col-sm-3 col-form-label">Keywords</label>
                                                        <div class="col-sm-9">
                                                            <div class="input-group">
                                                                <input type="text" class="form-control" id="keywords"
                                                                    name="keywords"
                                                                    placeholder="return, refund, exchange">
                                                                <button class="btn btn-outline-secondary" type="button"
                                                                    id="autoGenerateKeywords">
                                                                    Auto-generate
                                                                </button>
                                                            </div>
                                                            <div class="form-text">Comma separated keywords. Click
                                                                "Auto-generate" to extract from answer.</div>
                                                        </div>
                                                    </div>
                                                    <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                                                        <button type="submit" class="btn btn-primary">Add to Knowledge
                                                            Base</button>
                                                    </div>
                                                </form>
                                            </div>
                                        </div>

                                        <div class="card border-0 animate__animated animate__fadeInUp">
                                            <div class="d-flex justify-content-between align-items-center mb-3">
                                                <h5 class="mb-0">Your Knowledge Base</h5>
                                                <span class="badge bg-primary">
                                                    <%= knowledge ? knowledge.length : 0 %> entries
                                                </span>
                                            </div>
                                            <div class="card-body p-0">
                                                <% if (knowledge && knowledge.length> 0) { %>
                                                    <div class="list-group">
                                                        <% knowledge.forEach(item=> { %>
                                                            <div class="list-group-item list-group-item-action">
                                                                <div
                                                                    class="d-flex w-100 justify-content-between align-items-start">
                                                                    <div class="flex-grow-1">
                                                                        <div class="mb-2">
                                                                            <span class="badge bg-secondary me-2">
                                                                                <%= item.content_type.toUpperCase() %>
                                                                            </span>
                                                                            <strong>
                                                                                <%= item.question
                                                                                    || 'General Information' %>
                                                                            </strong>
                                                                        </div>
                                                                        <p class="mb-2 text-muted">
                                                                            <%= item.answer.substring(0, 200) %>
                                                                                <%= item.answer.length> 200 ? '...' : ''
                                                                                    %>
                                                                        </p>
                                                                        <% if (item.keywords) { %>
                                                                            <small class="text-muted">
                                                                                <i class="bi bi-tags"></i>
                                                                                <% const
                                                                                    keywords=item.keywords.split(',');
                                                                                    keywords.forEach((kw, i)=> { %>
                                                                                    <span
                                                                                        class="badge bg-light text-dark me-1">
                                                                                        <%= kw.trim() %>
                                                                                    </span>
                                                                                    <% }); %>
                                                                            </small>
                                                                            <% } %>
                                                                    </div>
                                                                    <div class="ms-2">
                                                                        <button
                                                                            class="btn btn-sm btn-outline-primary me-1 edit-btn"
                                                                            data-id="<%= item.id %>"
                                                                            data-type="<%= item.content_type %>"
                                                                            data-question="<%= item.question %>"
                                                                            data-answer="<%= item.answer %>"
                                                                            data-keywords="<%= item.keywords || '' %>">
                                                                            Edit
                                                                        </button>
                                                                        <form method="POST"
                                                                            action="/api/chatbot/knowledge/<%= item.id %>?_method=DELETE"
                                                                            style="display:inline;">
                                                                            <button type="submit"
                                                                                class="btn btn-sm btn-outline-danger"
                                                                                onclick="return confirm('Are you sure you want to delete this item?')">
                                                                                Delete
                                                                            </button>
                                                                        </form>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                            <% }); %>
                                                    </div>
                                                    <% } else { %>
                                                        <div class="text-center py-5">
                                                            <i class="bi bi-journal-x display-4 text-muted"></i>
                                                            <p class="text-muted mt-3">No knowledge items yet.</p>
                                                            <p class="text-muted small">Add your first FAQ, policy, or
                                                                use a template to get started.</p>
                                                        </div>
                                                        <% } %>
                                            </div>
                                        </div>
                                        <% } %>

                                            <!-- Embed Script Tab -->
                                            <% if (tab==='embed' ) { %>
                                                <div
                                                    class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                                    <h1 class="h2">Embed Script</h1>
                                                </div>

                                                <div class="card border-0  mb-4 animate__animated animate__fadeInUp">
                                                    <div class="card-body">
                                                        <p class="lead">Copy the script below and paste it into your
                                                            website's HTML code, just before the closing
                                                            <code></body></code> tag.</p>

                                                        <div class="position-relative">
                                                            <pre class="bg-dark text-light p-3 rounded" id="embedCode"
                                                                style="overflow-x: auto;"><%= embedCode || '' %></pre>
                                                            <button id="copyBtn"
                                                                class="btn btn-sm btn-outline-light position-absolute top-0 end-0 m-2">
                                                                Copy
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>

                                                <%- embedCode || '' %>
                                                    <% } %>

                                                        <!-- Analytics Tab -->
                                                        <% if (tab==='analytics' ) { %>
                                                            <div
                                                                class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pb-2 mb-3 animate__animated animate__fadeInDown">
                                                                <h1 class="h2">Conversation Analytics</h1>
                                                            </div>

                                                            <div
                                                                class="card border-0  animate__animated animate__fadeInUp">
                                                                <div class="card-body">
                                                                    <% if (typeof conversations==='undefined' ||
                                                                        conversations===null) { %>
                                                                        <!-- Skeleton Loader for Analytics -->
                                                                        <div class="skeleton-loader">
                                                                            <div class="skeleton skeleton-title mb-4">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text medium mb-3">
                                                                            </div>
                                                                            <div class="skeleton skeleton-text mb-3">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text short mb-4">
                                                                            </div>
                                                                            <div class="skeleton skeleton-title mb-4">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text medium mb-3">
                                                                            </div>
                                                                            <div class="skeleton skeleton-text mb-3">
                                                                            </div>
                                                                        </div>
                                                                        <% } else if (conversations &&
                                                                            conversations.length> 0) { %>
                                                                            <div class="list-group">
                                                                                <% conversations.forEach(conv=> { %>
                                                                                    <div class="list-group-item">
                                                                                        <div
                                                                                            class="d-flex w-100 justify-content-between mb-2">
                                                                                            <small class="text-muted">
                                                                                                <strong>Session:</strong>
                                                                                                <%= conv.session_id %>
                                                                                            </small>
                                                                                            <small class="text-muted">
                                                                                                <%= new
                                                                                                    Date(conv.created_at).toLocaleString()
                                                                                                    %>
                                                                                            </small>
                                                                                        </div>
                                                                                        <div class="mb-2">
                                                                                            <span
                                                                                                class="badge bg-primary">Customer:</span>
                                                                                            <span class="ms-2">
                                                                                                <%= conv.user_message %>
                                                                                            </span>
                                                                                        </div>
                                                                                        <div>
                                                                                            <span
                                                                                                class="badge bg-success">Bot:</span>
                                                                                            <span class="ms-2">
                                                                                                <%= conv.bot_response %>
                                                                                            </span>
                                                                                        </div>
                                                                                    </div>
                                                                                    <% }); %>
                                                                            </div>
                                                                            <% } else { %>
                                                                                <p class="text-muted text-center">No
                                                                                    conversations yet. Your chatbot will
                                                                                    start collecting data once embedded.
                                                                                </p>
                                                                                <% } %>
                                                                </div>
                                                            </div>
                                                            <% } %>

                                                                <!-- Knowledge Base Loading State -->
                                                                <% if (tab==='knowledge' ) { %>
                                                                    <div id="knowledgeLoading"
                                                                        class="card border-0  animate__animated animate__fadeInUp"
                                                                        style="display: none;">
                                                                        <div class="card-body">
                                                                            <div class="skeleton skeleton-title mb-4">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text medium mb-3">
                                                                            </div>
                                                                            <div class="skeleton skeleton-text mb-3">
                                                                            </div>
                                                                            <div
                                                                                class="skeleton skeleton-text short mb-4">
                                                                            </div>
                                                                        </div>
                                                                    </div>
                                                                    <% } %>
        </main>
        <% if (tab==='knowledge' ) { %>
            <!-- Edit Knowledge Modal -->
            <div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="editModalLabel">Edit Knowledge Base Entry</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <form method="POST" action="/api/chatbot/knowledge/" id="editForm">
                            <input type="hidden" name="_method" value="PUT">
                            <input type="hidden" id="editId" name="id">
                            <div class="modal-body">
                                <div class="mb-3">
                                    <label for="edit_content_type" class="form-label">Content Type</label>
                                    <select class="form-select" id="edit_content_type" name="content_type">
                                        <option value="faq">FAQ</option>
                                        <option value="policy">Policy</option>
                                        <option value="delivery">Delivery Info</option>
                                        <option value="refund">Refund Policy</option>
                                        <option value="product">Product Details</option>
                                        <option value="general">General</option>
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_question" class="form-label">Question/Topic</label>
                                    <input type="text" class="form-control" id="edit_question" name="question" required>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_answer" class="form-label">Answer</label>
                                    <textarea class="form-control" id="edit_answer" name="answer" rows="5"
                                        required></textarea>
                                </div>
                                <div class="mb-3">
                                    <label for="edit_keywords" class="form-label">Keywords</label>
                                    <input type="text" class="form-control" id="edit_keywords" name="keywords"
                                        placeholder="Comma separated keywords">
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                <button type="submit" class="btn btn-primary">Save Changes</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Bulk Import Modal -->
            <div class="modal fade" id="bulkImportModal" tabindex="-1" aria-labelledby="bulkImportModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="bulkImportModalLabel">Bulk Import Knowledge Base</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted">Import multiple knowledge base entries from a JSON file.</p>

                            <div class="mb-3">
                                <label for="jsonFile" class="form-label">Upload JSON File</label>
                                <input type="file" class="form-control" id="jsonFile" accept=".json">
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Or paste JSON data:</label>
                                <textarea class="form-control" id="jsonData" rows="8" placeholder='[
    {
      "content_type": "faq",
      "question": "What are your business hours?",
      "answer": "We are open Monday-Friday, 9am-6pm.",
      "keywords": "hours, open, schedule"
    }
]'></textarea>
                            </div>

                            <div class="alert alert-info">
                                <strong>Expected JSON format:</strong>
                                <pre class="mt-2 mb-0" style="font-size: 0.85rem;">[
  {
    "content_type": "faq|policy|delivery|refund|product|general",
    "question": "Your question here",
    "answer": "Your answer here",
    "keywords": "keyword1, keyword2"
  }
]</pre>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" id="importJsonBtn">Import Entries</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- AI Generate Modal -->
            <div class="modal fade" id="aiGenerateModal" tabindex="-1" aria-labelledby="aiGenerateModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="aiGenerateModalLabel">AI-Powered Content Generation</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <ul class="nav nav-tabs mb-3" id="aiTabs" role="tablist">
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link active" id="generate-faq-tab" data-bs-toggle="tab"
                                        data-bs-target="#generate-faq" type="button" role="tab">Generate FAQs</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="generate-answer-tab" data-bs-toggle="tab"
                                        data-bs-target="#generate-answer" type="button" role="tab">Generate
                                        Answer</button>
                                </li>
                                <li class="nav-item" role="presentation">
                                    <button class="nav-link" id="generate-keywords-tab" data-bs-toggle="tab"
                                        data-bs-target="#generate-keywords" type="button" role="tab">Extract
                                        Keywords</button>
                                </li>
                            </ul>

                            <div class="tab-content" id="aiTabsContent">
                                <!-- Generate FAQs Tab -->
                                <div class="tab-pane fade show active" id="generate-faq" role="tabpanel">
                                    <div class="mb-3">
                                        <label class="form-label">Describe your business:</label>
                                        <textarea class="form-control" id="businessDescription" rows="4"
                                            placeholder="E.g., We are an e-commerce store selling handmade jewelry. We ship worldwide and offer custom designs..."></textarea>
                                    </div>
                                    <button class="btn btn-primary" id="generateFaqBtn">
                                        <span id="generateFaqSpinner"
                                            class="spinner-border spinner-border-sm d-none"></span>
                                        Generate FAQs
                                    </button>
                                </div>

                                <!-- Generate Answer Tab -->
                                <div class="tab-pane fade" id="generate-answer" role="tabpanel">
                                    <div class="mb-3">
                                        <label class="form-label">Enter your question:</label>
                                        <input type="text" class="form-control" id="answerQuestion"
                                            placeholder="E.g., What is your return policy for custom orders?">
                                    </div>
                                    <button class="btn btn-primary" id="generateAnswerBtn">
                                        <span id="generateAnswerSpinner"
                                            class="spinner-border spinner-border-sm d-none"></span>
                                        Generate Answer
                                    </button>
                                </div>

                                <!-- Extract Keywords Tab -->
                                <div class="tab-pane fade" id="generate-keywords" role="tabpanel">
                                    <div class="mb-3">
                                        <label class="form-label">Enter text to extract keywords:</label>
                                        <textarea class="form-control" id="keywordText" rows="4"
                                            placeholder="Paste your content here..."></textarea>
                                    </div>
                                    <button class="btn btn-primary" id="extractKeywordBtn">
                                        <span id="generateKeywordsSpinner"
                                            class="spinner-border spinner-border-sm d-none"></span>
                                        Extract Keywords
                                    </button>
                                </div>
                            </div>

                            <!-- Generated Content Preview -->
                            <div id="generatedContent" class="mt-4 d-none">
                                <hr>
                                <h6>Generated Content:</h6>
                                <div id="generatedPreview" class="bg-light p-3 rounded"></div>
                                <button class="btn btn-sm btn-success mt-2" id="addToKnowledgeBaseBtn">Add to Knowledge
                                    Base</button>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Templates Modal -->
            <div class="modal fade" id="templatesModal" tabindex="-1" aria-labelledby="templatesModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="templatesModalLabel">Knowledge Base Templates</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted">Choose a template to quickly add common knowledge base entries for
                                your industry.
                            </p>

                            <div class="list-group" id="templatesList">
                                <!-- Templates will be loaded dynamically -->
                                <div class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
    </div>
</div>

<script src="/dashboard.js"></script>