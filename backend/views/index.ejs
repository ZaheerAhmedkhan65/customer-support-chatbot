<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Customer Support Chatbot - 24/7 Automated Support</title>
    <link rel="stylesheet" href="/styles.css">
</head>

<body>
    <nav class="navbar">
        <div class="nav-container">
            <div class="logo">
                <span class="logo-icon">🤖</span>
                <span class="logo-text">AI Support Bot</span>
            </div>
            <div class="nav-links">
                <a href="#features">Features</a>
                <a href="#pricing">Pricing</a>
                <% if (typeof user !== 'undefined' && user) { %>
                    <span class="user-email-nav"><%= user.email %></span>
                    <a href="/dashboard?token=<%= typeof token !== 'undefined' ? token : '' %>" class="btn-secondary">Dashboard</a>
                    <a href="#" onclick="logout(); return false;" class="btn-primary">Logout</a>
                <% } else { %>
                    <a href="/auth/signin" class="btn-secondary">Sign In</a>
                    <a href="/auth/signup" class="btn-primary">Get Started</a>
                <% } %>
            </div>
        </div>
    </nav>

    <section class="hero">
        <div class="hero-content">
            <h1>AI Customer Support That Works 24/7</h1>
            <p>Never miss a customer inquiry again. Our AI chatbot provides instant, accurate responses to your
                customers anytime, anywhere.</p>
            <div class="hero-buttons">
                <a href="/auth/signup" class="btn-primary-large">Start Free Trial</a>
                <a href="#demo" class="btn-secondary-large">Watch Demo</a>
            </div>
        </div>
    </section>

    <section id="features" class="features">
        <h2>Why Choose Our AI Chatbot?</h2>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon">🔌</div>
                <h3>Plug & Play</h3>
                <p>Add the chatbot to your site with a single script tag. No coding required. Works instantly on any
                    website.</p>
                <code
                    class="demo-code">&lt;script src="https://your-domain/chatbot.js" data-org-id="your_id"&gt;&lt;/script&gt;</code>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎮</div>
                <h3>Admin Controlled</h3>
                <p>You control exactly what the AI knows and answers. Add FAQs, policies, product details, and more.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">⏰</div>
                <h3>Always Online</h3>
                <p>Your customers get 24/7 support even when you're sleeping. Never lose a sale due to unanswered
                    questions.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">📊</div>
                <h3>Analytics Dashboard</h3>
                <p>Track conversations, customer satisfaction, and common questions. Make data-driven decisions.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🎨</div>
                <h3>Customizable</h3>
                <p>Match the chatbot to your brand with custom colors, position, and welcome messages.</p>
            </div>
            <div class="feature-card">
                <div class="feature-icon">🔒</div>
                <h3>Secure & Private</h3>
                <p>Your data is encrypted and secure. GDPR compliant with full control over your information.</p>
            </div>
        </div>
    </section>

    <section id="demo" class="demo">
        <h2>See It In Action</h2>
        <div class="demo-container">
            <div class="demo-info">
                <h3>Live Preview</h3>
                <p>Click the chat button on the right to see how our AI assistant responds to customer questions
                    instantly.</p>
                <ul>
                    <li>✅ Instant responses</li>
                    <li>✅ 24/7 availability</li>
                    <li>✅ Natural conversations</li>
                    <li>✅ Smart knowledge base</li>
                </ul>
                <a href="/auth/signup" class="btn-primary">Start Your Free Trial →</a>
            </div>
            <div class="demo-preview">
                <img src="https://via.placeholder.com/400x600?text=Chatbot+Preview" alt="Chatbot Preview">
            </div>
        </div>
    </section>

    <section id="pricing" class="pricing">
        <h2>Simple, Transparent Pricing</h2>
        <div class="pricing-grid">
            <div class="pricing-card">
                <h3>Starter</h3>
                <div class="price">$29<span>/month</span></div>
                <ul>
                    <li>1,000 conversations/month</li>
                    <li>Basic knowledge base</li>
                    <li>Email support</li>
                    <li>Basic analytics</li>
                </ul>
                <a href="/auth/signup" class="btn-secondary">Get Started</a>
            </div>
            <div class="pricing-card popular">
                <div class="popular-badge">Most Popular</div>
                <h3>Professional</h3>
                <div class="price">$79<span>/month</span></div>
                <ul>
                    <li>10,000 conversations/month</li>
                    <li>Advanced knowledge base</li>
                    <li>Priority support</li>
                    <li>Advanced analytics</li>
                    <li>Custom branding</li>
                    <li>API access</li>
                </ul>
                <a href="/auth/signup" class="btn-primary">Get Started</a>
            </div>
            <div class="pricing-card">
                <h3>Enterprise</h3>
                <div class="price">Custom</div>
                <ul>
                    <li>Unlimited conversations</li>
                    <li>Custom AI training</li>
                    <li>24/7 phone support</li>
                    <li>Dedicated account manager</li>
                    <li>SLA guarantee</li>
                    <li>On-premise deployment</li>
                </ul>
                <a href="#" class="btn-secondary">Contact Sales</a>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h4>AI Support Bot</h4>
                <p>Intelligent customer support for modern businesses.</p>
            </div>
            <div class="footer-section">
                <h4>Product</h4>
                <a href="#features">Features</a>
                <a href="#pricing">Pricing</a>
                <a href="#demo">Demo</a>
            </div>
            <div class="footer-section">
                <h4>Company</h4>
                <a href="#">About</a>
                <a href="#">Blog</a>
                <a href="#">Contact</a>
            </div>
            <div class="footer-section">
                <h4>Legal</h4>
                <a href="#">Privacy</a>
                <a href="#">Terms</a>
                <a href="#">Security</a>
            </div>
        </div>
    </footer>

    <!-- Demo Chatbot for the homepage -->
    <script>
        // This would be replaced with actual embed code in production
        console.log('Demo chatbot ready');
        
        // Logout function
        function logout() {
            localStorage.removeItem('token');
            localStorage.removeItem('user');
            window.location.href = '/';
        }
        
        // Check if user is logged in via localStorage and update nav
        document.addEventListener('DOMContentLoaded', function() {
            const token = localStorage.getItem('token');
            const user = JSON.parse(localStorage.getItem('user') || 'null');
            
            if (token && user) {
                const navLinks = document.querySelector('.nav-links');
                
                // Check if already showing logged in state from server
                if (!navLinks.querySelector('.user-email-nav')) {
                    // Update nav to show logged in state
                    navLinks.innerHTML = `
                        <a href="#features">Features</a>
                        <a href="#pricing">Pricing</a>
                        <span class="user-email-nav">${user.email}</span>
                        <a href="/dashboard" class="btn-secondary">Dashboard</a>
                        <a href="#" onclick="logout(); return false;" class="btn-primary">Logout</a>
                    `;
                }
            }
        });
    </script>
</body>

</html>